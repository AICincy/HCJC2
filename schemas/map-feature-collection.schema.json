{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://data.aretheyinjail.com/schemas/map-feature-collection/1.0.0",
  "title": "HCJC2 Public Map Features",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "schema_uri",
    "schema_version",
    "dataset_id",
    "release_id",
    "generated_at",
    "source_status",
    "result_window",
    "features"
  ],
  "properties": {
    "type": {
      "const": "FeatureCollection"
    },
    "schema_uri": {
      "const": "https://data.aretheyinjail.com/schemas/map-feature-collection/1.0.0"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "dataset_id": {
      "const": "hcjc2.map.public_safety"
    },
    "release_id": {
      "type": "string"
    },
    "generated_at": {
      "$ref": "https://data.aretheyinjail.com/schemas/common/1.0.0#/$defs/utcInstant"
    },
    "source_status": {
      "$ref": "https://data.aretheyinjail.com/schemas/common/1.0.0#/$defs/sourceStatus"
    },
    "result_window": {
      "$ref": "https://data.aretheyinjail.com/schemas/common/1.0.0#/$defs/resultWindow"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "id",
          "geometry",
          "properties"
        ],
        "properties": {
          "type": {
            "const": "Feature"
          },
          "id": {
            "type": "string"
          },
          "geometry": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "coordinates"
            ],
            "properties": {
              "type": {
                "const": "Point"
              },
              "coordinates": {
                "type": "array",
                "prefixItems": [
                  {
                    "type": "number",
                    "minimum": -180,
                    "maximum": 180
                  },
                  {
                    "type": "number",
                    "minimum": -90,
                    "maximum": 90
                  }
                ],
                "items": false
              }
            }
          },
          "properties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "event_type",
              "source_ref",
              "event_time",
              "location_precision",
              "display_label"
            ],
            "properties": {
              "event_type": {
                "type": "string"
              },
              "source_ref": {
                "$ref": "https://data.aretheyinjail.com/schemas/common/1.0.0#/$defs/sourceRef"
              },
              "event_time": {
                "$ref": "https://data.aretheyinjail.com/schemas/common/1.0.0#/$defs/temporalValue"
              },
              "location_precision": {
                "enum": [
                  "exact",
                  "block",
                  "intersection",
                  "approximate",
                  "unknown"
                ]
              },
              "display_label": {
                "type": "string"
              },
              "address_display": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "neighborhood": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      }
    }
  }
}
